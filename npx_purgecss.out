 npx purgecss \
  --css public/scss/main.css \
  --content "public/**/*.html"
[{"css":"@charset \"UTF-8\";\n/*\n\nAdd styles or override variables from the theme here.\n\n*/\n@import url(\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap\");\n@import url(\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@400;500&display=swap\");\n@import url(\"https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,700,700i&display=swap\");\nhtml {\n  font-size: 16px; }\n\nbody {\n  color: #162033;\n  font-family: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n  font-size: 1.07rem;\n  line-height: 1.68;\n  -webkit-font-smoothing: antialiased;\n  text-rendering: optimizeLegibility; }\n\nh1, .h1, h2, .h2, h3, .h3, .td-footer__links-item, h5, .h5,\n.td-content h1, .td-content h2, .td-content h3, .td-content h5 {\n  color: #0f172a;\n  font-family: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n  font-weight: 600;\n  letter-spacing: -0.02em;\n  line-height: 1.2; }\n\n.td-content {\n  color: #162033;\n  font-size: 1.05rem; }\n\n.td-content p,\n.td-content li,\n.td-content dt {\n  color: #162033; }\n\n.td-content p,\n.td-content li {\n  line-height: 1.72; }\n\n.td-content small, .td-content .small, .td-content .td-footer__center {\n  color: #5b667a; }\n\ncode,\npre,\n.highlight code {\n  font-family: \"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, monospace; }\n\n.td-content pre,\n.td-content .highlight pre {\n  border: 1px solid #e4e9f2;\n  border-radius: 14px;\n  box-shadow: none; }\n\n.td-content table {\n  border-color: #e4e9f2; }\n\n.td-content img {\n  border-radius: 12px; }\n\n.td-navbar {\n  background-color: #ffffff !important;\n  border-bottom: none !important;\n  box-shadow: none !important; }\n  .td-navbar .nav-link {\n    color: #000000 !important;\n    text-shadow: none !important; }\n    .td-navbar .nav-link:hover, .td-navbar .nav-link:focus {\n      color: #1473e6 !important;\n      text-shadow: none !important; }\n  .td-navbar .navbar-brand {\n    color: #000000 !important; }\n\n.td-search input.form-control {\n  background-color: #ffffff !important;\n  border: 1px solid rgba(20, 115, 230, 0.18) !important;\n  color: #0f172a !important;\n  border-radius: 10px !important;\n  box-shadow: 0 2px 10px rgba(20, 115, 230, 0.08); }\n  .td-search input.form-control::placeholder {\n    color: #7b8aa0 !important;\n    opacity: 1 !important; }\n  .td-search input.form-control:focus {\n    background-color: #ffffff !important;\n    border-color: rgba(20, 115, 230, 0.4) !important;\n    box-shadow: 0 0 0 0.2rem rgba(20, 115, 230, 0.12) !important;\n    color: #0f172a !important; }\n\n.td-search button {\n  background-color: #1473e6 !important;\n  border-color: #1473e6 !important;\n  color: #ffffff !important;\n  border-radius: 10px !important; }\n  .td-search button:hover {\n    background-color: #0f5fc0 !important;\n    border-color: #0f5fc0 !important; }\n\n.td-footer {\n  background-color: #ffffff !important; }\n\nfooter {\n  color: #000000 !important; }\n  footer a {\n    color: #000000 !important; }\n    footer a:hover {\n      color: #1473e6 !important; }\n   footer .td-search__icon::before,\n  footer .fas,\n  footer .far,\n  footer .fab {\n    color: #000000 !important; }\n  footer p {\n    color: #000000 !important; }\n\n/* Ensure the equation container is the anchor */\n .katex {\n  position: relative !important;\n  display: inline-block; }\n\n/* The invisible bridge to prevent mouse-out when moving toward the button */\n.katex:hover::before {\n  content: \"\";\n  position: absolute;\n  top: -20px;\n  right: 0;\n  left: 0;\n  bottom: 0;\n  z-index: 1;\n  /* Sits below the button but keeps hover active */ }\n\n/* The Copy Button styling */\n\n/* Specific adjustment for Inline equations inside sentences */\n\n/* Button Hover State */\n\n/* Success State */\n\n.video-link-container {\n  margin: 1.25rem 0; }\n\n.video-btn {\n  background-color: #fff4f7;\n  border: 1px solid #f3d4dd;\n  padding: 0.9rem 1rem;\n  border-radius: 14px;\n  font-weight: 500;\n  color: #162033;\n  display: inline-flex;\n  align-items: center;\n  gap: 0.9rem;\n  transition: all 0.2s ease-in-out;\n  text-decoration: none;\n  width: auto;\n  max-width: 100%;\n  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04); }\n\n.video-btn:hover {\n  transform: translateY(-1px);\n  background-color: #ffe9f0;\n  border-color: #e8bccb;\n  box-shadow: 0 12px 24px rgba(159, 18, 57, 0.1);\n  color: #162033;\n  text-decoration: none; }\n\n.video-btn__icon {\n  width: 2.5rem;\n  height: 2.5rem;\n  border-radius: 999px;\n  background: #fde8ef;\n  color: #dc2626;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  flex: 0 0 auto; }\n\n.video-btn__icon i {\n  font-size: 1rem; }\n\n.video-btn__content {\n  display: flex;\n  flex-direction: column;\n  gap: 0.12rem; }\n\n.video-btn__eyebrow {\n  color: #5b667a;\n  font-size: 0.76rem;\n  font-weight: 600;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  opacity: 0.72; }\n\n.video-btn__title {\n  color: #111827;\n  font-size: 1rem;\n  font-weight: 600;\n  line-height: 1.35; }\n\n.video-btn-playlist .video-btn__icon {\n  background: #eff6ff;\n  color: #2563eb; }\n\n.video-btn-playlist {\n  background-color: #f5f9ff;\n  border-color: #d6e5ff; }\n\n.video-btn-playlist:hover {\n  background-color: #edf5ff;\n  border-color: #c1d8ff;\n  box-shadow: 0 12px 24px rgba(37, 99, 235, 0.08); }\n\n.td-main,\n.td-content,\n.td-sidebar,\n.td-sidebar__inner,\n.td-sidebar-nav {\n  border: none !important;\n  box-shadow: none !important;\n  background-color: #ffffff !important; }\n\n.td-sidebar .td-sidebar-nav__section-title .td-sidebar-link:hover {\n  color: #1473e6 !important; }\n\n.td-content a {\n  color: #B8945A; }\n\n.td-content a:hover {\n  color: #9a7340;\n  text-decoration: underline; }\n\n.td-sidebar .td-sidebar-nav__section-title .td-sidebar-link:hover {\n  color: #9a7340 !important; }\n\n.rs-callout {\n  --rs-callout-accent: #7db7ff;\n  --rs-callout-accent-strong: #2563eb;\n  --rs-callout-surface: #f7f9fc;\n  background: #f7f9fc;\n  border: 1px solid #e4e9f2;\n  border-radius: 16px;\n  box-shadow: none;\n  color: #162033;\n  display: block;\n  margin: 1.1rem 0;\n  padding: 1rem 1.1rem;\n  width: 100%; }\n\n.rs-callout__title,\n.rs-callout__label {\n  color: #0f172a;\n  font-size: 1.02rem;\n  font-weight: 600;\n  letter-spacing: -0.01em;\n  line-height: 1.4;\n  margin-bottom: 0.45rem; }\n\n.rs-callout__title--panel {\n  color: var(--rs-callout-accent-strong);\n  font-size: 1.18rem; }\n\n.rs-callout__label {\n  color: #5b667a;\n  font-size: 0.8rem;\n  letter-spacing: 0.08em;\n  margin-bottom: 0.4rem;\n  text-transform: uppercase; }\n\n.rs-callout__body,\n.rs-callout__body > :last-child {\n  color: #162033; }\n\n.rs-callout__body > *:last-child {\n  margin-bottom: 0; }\n\n.rs-callout-blue {\n  --rs-callout-accent: #93c5fd;\n  --rs-callout-accent-strong: #1d4ed8;\n  --rs-callout-surface: #eff6ff; }\n\n.rs-callout-green {\n  --rs-callout-accent: #86efac;\n  --rs-callout-accent-strong: #15803d;\n  --rs-callout-surface: #f0fdf4; }\n\n.rs-callout-magenta {\n  --rs-callout-accent: #e9d5ff;\n  --rs-callout-accent-strong: #9333ea;\n  --rs-callout-surface: #faf5ff; }\n\n.rs-callout-orange {\n  --rs-callout-accent: #fed7aa;\n  --rs-callout-accent-strong: #c2410c;\n  --rs-callout-surface: #fff7ed; }\n\n.rs-callout-red,\n.rs-callout-rust {\n  --rs-callout-accent: #fecaca;\n  --rs-callout-accent-strong: #b91c1c;\n  --rs-callout-surface: #fef2f2; }\n\n.rs-callout-cyan {\n  --rs-callout-accent: #a5f3fc;\n  --rs-callout-accent-strong: #0f766e;\n  --rs-callout-surface: #ecfeff; }\n\n.rs-callout-navy {\n  --rs-callout-accent: #c7d2fe;\n  --rs-callout-accent-strong: #3730a3;\n  --rs-callout-surface: #eef2ff; }\n\n.rs-callout-grey {\n  --rs-callout-accent: #cbd5e1;\n  --rs-callout-accent-strong: #475569;\n  --rs-callout-surface: #f8fafc; }\n\n.rs-callout-gold {\n  --rs-callout-accent: #f2c12e;\n  --rs-callout-accent-strong: #785c00;\n  --rs-callout-surface: #fffbe6; }\n\n.rs-callout-panel {\n  background: linear-gradient(180deg, color-mix(in srgb, var(--rs-callout-surface) 92%, #ffffff 8%) 0%, var(--rs-callout-surface) 100%);\n  border-left: 3px solid var(--rs-callout-accent); }\n\n.rs-callout-definition {\n  background: linear-gradient(180deg, color-mix(in srgb, var(--rs-callout-surface) 92%, #ffffff 8%) 0%, var(--rs-callout-surface) 100%);\n  border-left: 3px solid var(--rs-callout-accent); }\n\n.rs-callout-question {\n  background: #f6fcf8;\n  border-left: 3px solid #86efac; }\n\n.rs-callout-answer {\n  background: #fbf8ff;\n  border-left: 3px solid #e9d5ff; }\n\n.rs-figure {\n  margin: 1.75rem 0;\n  text-align: center; }\n\n.rs-figure__image {\n  border: 1px solid #e4e9f2;\n  border-radius: 14px;\n  height: auto;\n  max-width: 100%; }\n\n.support-page {\n  max-width: 980px;\n  margin: 0 auto;\n  text-align: center;\n  width: 100%; }\n\n.support-banner {\n  display: block;\n  margin: 0 auto 18px;\n  padding: 1rem 1.1rem;\n  border: 1px solid #e4e9f2;\n  border-left: 3px solid #8ab4ff;\n  border-radius: 16px;\n  background: #f8fbff;\n  color: #162033 !important;\n  font-weight: 500;\n  font-size: 1rem;\n  line-height: 1.65;\n  text-align: center; }\n\n.support-grid {\n  width: 100%;\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 18px;\n  align-items: stretch;\n  justify-items: stretch; }\n\n.support-card {\n  background: #ffffff;\n  border: 1px solid #e4e9f2;\n  border-radius: 18px;\n  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);\n  padding: 20px;\n  margin: 0;\n  max-width: none;\n  min-height: 430px;\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-start;\n  align-items: center; }\n\n.support-card .support-note {\n  text-align: center;\n  margin-left: auto;\n  margin-right: auto; }\n\n.support-card-title {\n  color: #0f172a;\n  font-size: 1.05rem;\n  font-weight: 600;\n  margin-bottom: 12px;\n  min-height: 2.2rem;\n  display: flex;\n  align-items: center;\n  justify-content: center; }\n\n.support-qr {\n  width: 100%;\n  max-width: 170px;\n  height: auto;\n  border-radius: 8px; }\n\n.support-media {\n  width: 100%;\n  min-height: 220px;\n  display: flex;\n  align-items: center;\n  justify-content: center; }\n\n.support-qr-frame {\n  display: inline-block;\n  padding: 10px;\n  border: 1px solid #d7e3f4;\n  border-radius: 12px;\n  background: #ffffff;\n  box-shadow: 0 3px 16px rgba(15, 23, 42, 0.08); }\n\n.support-actions {\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: center;\n  gap: 12px;\n  margin: 14px 0; }\n\nbody.td-home .td-main {\n  padding: 0; }\n\n.rs-simple-shell {\n  max-width: 1280px; }\n\n.rs-courses-section {\n  background: #ffffff;\n  padding: 0rem 0 0.5rem; }\n\n.rs-course-heading {\n  margin: 0 auto 1.5rem;\n  max-width: 780px;\n  text-align: center; }\n\n.rs-course-heading h1, .rs-course-heading .h1 {\n  color: #0f172a;\n  font-size: clamp(2.3rem, 4vw, 3.8rem);\n  font-weight: 700;\n  letter-spacing: -0.04em;\n  line-height: 1.02;\n  margin: 0 0 0.6rem; }\n\n.rs-course-heading p {\n  color: #5b667a;\n  font-size: 1.04rem;\n  line-height: 1.72;\n  margin: 0 auto;\n  max-width: 46rem; }\n\n.rs-course-list {\n  display: grid;\n  gap: 0.95rem; }\n\n.rs-course-row {\n  display: grid;\n  grid-template-columns: minmax(220px, 0.9fr) minmax(0, 1.8fr) auto;\n  gap: 1.25rem;\n  align-items: center;\n  background: #ffffff;\n  border: 1px solid #e7ecf3;\n  border-radius: 1.5rem;\n  color: inherit;\n  padding: 1.25rem 1.35rem;\n  text-decoration: none;\n  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease; }\n\n.rs-course-row:hover {\n  color: inherit;\n  text-decoration: none;\n  transform: translateY(-1px);\n  box-shadow: 0 14px 26px rgba(15, 23, 42, 0.04); }\n\n.rs-course-row__meta h2, .rs-course-row__meta .h2 {\n  color: #0f172a;\n  font-size: 1.5rem;\n  margin: 0.2rem 0 0; }\n\n.rs-course-row__eyebrow {\n  display: inline-block;\n  font-size: 0.78rem;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  text-transform: uppercase; }\n\n.rs-course-row__description {\n  color: #5b667a;\n  font-size: 1rem;\n  line-height: 1.72;\n  margin: 0; }\n\n.rs-course-row__cta {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.65rem;\n  color: #0f172a;\n  font-size: 0.96rem;\n  font-weight: 600;\n  white-space: nowrap; }\n\n/* ── Course rows: unified gold-tan family ───────── */\n/* NLP - Warm Amber Gold Accent */\n.rs-course-row--nlp {\n  background: linear-gradient(90deg, #fffbf2 0%, #fff 28%);\n  border-color: #ebdcb9; }\n\n.rs-course-row--nlp .rs-course-row__eyebrow {\n  color: #b58925; }\n\n/* DL - Rich Ochre Gold Accent */\n.rs-course-row--dl {\n  background: linear-gradient(90deg, #fffaf0 0%, #fff 28%);\n  border-color: #e6d3a8; }\n\n.rs-course-row--dl .rs-course-row__eyebrow {\n  color: #a87f1e; }\n\n/* ML - Soft Champagne Gold Accent */\n.rs-course-row--ml {\n  background: linear-gradient(90deg, #fffcf5 0%, #fff 28%);\n  border-color: #eedfb8; }\n\n.rs-course-row--ml .rs-course-row__eyebrow {\n  color: #bd922b; }\n\n/* MATHS - Deep Earthy Tan Accent */\n.rs-course-row--maths {\n  background: linear-gradient(90deg, #fff9ee 0%, #fff 28%);\n  border-color: #e3ce9c; }\n\n.rs-course-row--maths .rs-course-row__eyebrow {\n  color: #9e7517; }\n\n@media (max-width: 767.98px) {\n  .rs-courses-section {\n    padding: 0rem 0 1.25rem; }\n  .rs-course-row {\n    grid-template-columns: 1fr; }\n  .rs-course-heading {\n    text-align: center; }\n  .rs-course-row {\n    gap: 0.9rem; }\n  .rs-course-row__cta {\n    white-space: normal; } }\n\n.rs-course-overview {\n  margin: 1rem 0 0; }\n\n.rs-course-overview h2, .rs-course-overview .h2 {\n  color: #0f172a;\n  font-size: clamp(1.45rem, 1.9vw, 1.95rem);\n  letter-spacing: -0.03em;\n  margin-bottom: 0.7rem; }\n\n.rs-course-overview__includes,\n.rs-course-overview__stats {\n  margin-bottom: 0.5rem !important; }\n\n.rs-course-overview__stats {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.7rem;\n  grid-template-columns: repeat(3, minmax(0, 1fr)); }\n\n.rs-course-overview__stat {\n  display: flex;\n  align-items: center;\n  gap: 0.7rem;\n  background: #ffffff;\n  border: 1px solid #e4e9f2;\n  border-radius: 14px;\n  padding: 0.75rem 0.85rem;\n  font-size: 0.94rem;\n  flex: 0 1 auto;\n  white-space: nowrap; }\n\n.rs-course-overview__icon {\n  width: 2.2rem;\n  height: 2.2rem;\n  border-radius: 999px;\n  background: #f7f9fc;\n  color: #334155;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  flex: 0 0 auto; }\n\n.rs-course-overview__header {\n  display: flex;\n  align-items: end;\n  justify-content: space-between;\n  gap: 1rem;\n  margin-top: 0.75rem;\n  margin-bottom: 0.4rem; }\n\n.rs-course-overview__header p {\n  color: #5b667a;\n  font-size: 0.92rem;\n  line-height: 1.55;\n  margin: 0; }\n\n.rs-course-overview__expand {\n  background: transparent;\n  border: none;\n  color: #6d28d9;\n  cursor: pointer;\n  font-size: 0.9rem;\n  font-weight: 700;\n  padding: 0; }\n\n.rs-course-overview__expand:hover {\n  color: #5b21b6;\n  text-decoration: underline; }\n\n.rs-course-outline {\n  margin-top: 0rem;\n  display: grid;\n  gap: 0.45rem; }\n\n.rs-course-outline__section {\n  background: #ffffff;\n  border: 1px solid #e4e9f2;\n  border-radius: 16px;\n  overflow: hidden; }\n\n.rs-course-outline__section summary {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 1rem;\n  cursor: pointer;\n  list-style: none;\n  padding: 0.8rem 0.95rem; }\n\n.rs-course-outline__section summary::-webkit-details-marker {\n  display: none; }\n\n.rs-course-outline__summary-text {\n  color: #0f172a;\n  font-size: 1rem;\n  font-weight: 600; }\n\n.rs-course-outline__summary-meta {\n  color: #5b667a;\n  font-size: 0.86rem;\n  white-space: nowrap; }\n\n.rs-course-outline__items {\n  border-top: 1px solid #eef2f7;\n  padding: 0.15rem 0.95rem 0.75rem; }\n\n.rs-course-outline__item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 0.8rem;\n  padding: 0.65rem 0; }\n\n.rs-course-outline__item + .rs-course-outline__item {\n  border-top: 1px solid #f2f5fa; }\n\n.rs-course-outline__item-main {\n  display: flex;\n  align-items: center;\n  gap: 0.65rem; }\n\n.rs-course-outline__item-icon {\n  color: #4b5563;\n  width: 1rem;\n  text-align: center;\n  flex: 0 0 auto;\n  font-size: 0.92rem; }\n\n.rs-course-outline__item-title {\n  color: #243047;\n  font-size: 0.95rem;\n  line-height: 1.45; }\n\n.rs-course-outline__item-meta {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.55rem;\n  color: #667085;\n  flex: 0 0 auto;\n  font-size: 0.9rem; }\n\n.rs-course-outline__item-meta a {\n  color: #7c3aed;\n  text-decoration: none; }\n\n.rs-course-outline__item-meta a:hover {\n  color: #6d28d9;\n  text-decoration: underline; }\n\n@media (max-width: 767.98px) {\n  .rs-course-overview__stats {\n    grid-template-columns: 1fr; }\n  .rs-course-overview {\n    margin-top: 1.25rem; }\n  .rs-course-overview__header,\n  .rs-course-outline__section summary,\n  .rs-course-outline__item {\n    align-items: flex-start;\n    flex-direction: column; }\n  .rs-course-outline__summary-meta,\n  .rs-course-outline__item-meta {\n    white-space: normal; } }\n\n.support-btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  border-radius: 10px;\n  padding: 10px 18px;\n  font-weight: 600;\n  text-decoration: none !important;\n  border: 1px solid transparent; }\n\n.support-btn-gpay {\n  background: #f4f8ff;\n  border-color: #cfe0ff;\n  color: #0f172a !important; }\n\n.support-btn-phonepe {\n  background: #f7f4ff;\n  border-color: #ddd0ff;\n  color: #0f172a !important; }\n\n.support-btn:hover {\n  color: #0f172a !important;\n  transform: translateY(-1px); }\n\n.support-app-icon {\n  width: 1.4rem;\n  height: 1.4rem;\n  border-radius: 999px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 0.78rem;\n  font-weight: 700;\n  line-height: 1; }\n\n.support-app-icon-gpay {\n  background: #eaf2ff;\n  color: #1a56d6; }\n\n.support-app-icon-phonepe {\n  background: #f0eaff;\n  color: #5b21b6; }\n\n.support-note {\n  color: #5b667a;\n  max-width: 34ch; }\n\n.support-razorpay-wrap {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  width: 100%;\n  min-height: 0; }\n\n.support-razorpay-wrap form {\n  display: inline-block;\n  transform: scale(1.02);\n  transform-origin: center top; }\n\n.support-card-intl .support-razorpay-wrap form {\n  transform: scale(1.5); }\n\n@media (max-width: 991.98px) {\n  .support-page {\n    margin-top: 16px; }\n  .support-razorpay-wrap form {\n    transform: scale(1); }\n  .support-card-intl .support-razorpay-wrap form {\n    transform: scale(1); }\n  .support-grid {\n    grid-template-columns: 1fr; }\n  .support-card {\n    min-height: auto; }\n  .support-media {\n    min-height: auto; } }\n\n@media (min-width: 992px) {\n  .support-page {\n    min-height: calc(100vh - 120px);\n    padding-top: 72px;\n    padding-bottom: 32px;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center; } }\n\nhtml {\n  font-size: 16px; }\n\nbody {\n  color: #162033;\n  font-family: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n  line-height: 1.2;\n  -webkit-font-smoothing: antialiased;\n  text-rendering: optimizeLegibility; }\n\n.td-content {\n  color: #162033;\n  max-width: 740px;\n  margin-left: 0rem;\n  margin-right: auto;\n  padding-left: 0; }\n  .td-content p {\n    font-family: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n    line-height: 1.2;\n    margin-bottom: 0.85rem;\n    color: #162033; }\n  .td-content ul, .td-content ol {\n    padding-left: 1.25rem;\n    margin-top: 0.25rem;\n    margin-bottom: 0.85rem; }\n  .td-content li {\n    font-family: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n    line-height: 1.1;\n    margin-bottom: 0.35rem;\n    color: #162033; }\n    .td-content li strong, .td-content li b {\n      color: #000000;\n      font-weight: 600; }\n  .td-content h1, .td-content .h1, .td-content h2, .td-content .h2, .td-content h3, .td-content .h3, .td-content .td-footer__links-item, .td-content h5, .td-content .h5 {\n    color: #0f172a;\n    font-family: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n    letter-spacing: -0.02em;\n    line-height: 1.2; }\n  .td-content h1, .td-content .h1 {\n    font-size: 1.85rem;\n    font-weight: 700;\n    margin-top: 1.5rem;\n    margin-bottom: 0.95rem; }\n  .td-content h2, .td-content .h2 {\n    font-size: 1.4rem;\n    font-weight: 700;\n    margin-top: 1.65rem;\n    margin-bottom: 0.75rem; }\n  .td-content h3, .td-content .h3, .td-content .td-footer__links-item {\n    font-size: 1.15rem;\n    font-weight: 600;\n    margin-top: 1.4rem;\n    margin-bottom: 0.5rem; }\n\n.rs-figure, .rs-callout {\n  max-width: 100%; }\n\n/* ── Navbar: white, bordered, not translucent ────────── */\n.td-navbar {\n  background: #fff !important;\n  border-bottom: 1px solid #e4e4e0;\n  box-shadow: none !important; }\n\n.td-navbar .navbar-brand__name {\n  font-family: 'DM Sans', sans-serif;\n  font-weight: 600;\n  letter-spacing: -0.02em;\n  color: #0a0a0a; }\n\n.td-navbar .nav-link {\n  color: #2c2c2c !important;\n  font-weight: 500;\n  font-size: 0.875rem;\n  letter-spacing: 0.01em; }\n\n.td-navbar .nav-link:hover {\n  color: #0a0a0a !important; }\n\n/* ── Remove translucency on cover ────────────────────── */\n\n/* ── Hero ──────────────────────────────────────────────── */\n.rs-hero {\n  background: #fff;\n  border-bottom: 1px solid #e4e4e0;\n  padding: 7rem 2 0.5rem !important;\n  text-align: center;\n  border-bottom: none !important; }\n\n.rs-hero__inner {\n  max-width: 680px;\n  margin: 0 auto; }\n\n.rs-eyebrow {\n  font-size: 0.75rem;\n  font-weight: 500;\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  color: #B8945A;\n  margin-bottom: 1.25rem; }\n\n.rs-h1 {\n  font-family: 'Playfair Display', serif;\n  font-size: clamp(2.6rem, 5vw, 4rem);\n  font-weight: 900;\n  line-height: 1.1;\n  color: #0a0a0a;\n  margin-bottom: 1.25rem;\n  letter-spacing: -0.02em; }\n\n.rs-h1 em {\n  font-style: italic;\n  color: #B8945A; }\n\n.rs-sub {\n  font-size: 1.05rem;\n  color: #5a5a5a;\n  font-weight: 300;\n  line-height: 1.7;\n  margin-bottom: 0.25rem; }\n\n.rs-cta-row {\n  display: flex;\n  gap: 1rem;\n  justify-content: center;\n  flex-wrap: wrap;\n  margin-bottom: 3.5rem; }\n\n.rs-btn-primary {\n  background: #0a0a0a;\n  color: #fff;\n  padding: 0.8rem 2rem;\n  border-radius: 12px;\n  font-weight: 600;\n  font-size: 0.9rem;\n  text-decoration: none;\n  transition: background 0.2s, transform 0.15s;\n  letter-spacing: 0.02em; }\n\n.rs-btn-primary:hover {\n  background: #B8945A;\n  color: #fff;\n  transform: translateY(-1px);\n  text-decoration: none; }\n\n.rs-btn-ghost {\n  color: #0a0a0a;\n  padding: 0.8rem 1.5rem;\n  border: 1px solid #e4e4e0;\n  border-radius: 12px;\n  font-weight: 500;\n  font-size: 0.9rem;\n  text-decoration: none;\n  transition: border-color 0.2s; }\n\n.rs-btn-ghost:hover {\n  border-color: #0a0a0a;\n  text-decoration: none;\n  color: #0a0a0a; }\n\n.rs-stats {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  border: 1px solid #e4e4e0;\n  border-radius: 3px;\n  overflow: hidden; }\n\n.rs-stat {\n  padding: 0.9rem 0.5rem 0.75rem;\n  border-right: 1px solid #e4e4e0;\n  text-align: center; }\n\n.rs-stat:last-child {\n  border-right: none; }\n\n.rs-stat__num {\n  display: block;\n  font-family: 'Playfair Display', serif;\n  font-size: 1.6rem;\n  font-weight: 900;\n  color: #0a0a0a; }\n\n.rs-stat__label {\n  font-size: 0.7rem;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  color: #8a8a8a;\n  margin-top: 0.15rem; }\n\n@media (max-width: 600px) {\n  .rs-stats {\n    grid-template-columns: 1fr 1fr; }\n  .rs-stat:nth-child(2) {\n    border-right: none; }\n  .rs-stat:nth-child(3),\n  .rs-stat:nth-child(4) {\n    border-top: 1px solid #e4e4e0; } }\n\n/* ── Sidebar Refinement ────────────────────────────────── */\n.td-sidebar-nav {\n  font-size: 0.8125rem;\n  /* 13px */\n  padding: 1.5rem 0; }\n\n/* Section-level (L1) — bold, uppercase, spaced */\n.td-sidebar-nav .td-sidebar-nav__section > li > a,\n.td-sidebar-nav .td-sidebar-nav__section > li > span {\n  font-weight: 600;\n  font-size: 0.75rem;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  color: #0a0a0a;\n  padding: 0.5rem 1.25rem;\n  margin-top: 0.5rem; }\n\n/* Active state — gold underline, not blue background */\n.td-sidebar-nav .active > a {\n  color: #0a0a0a !important;\n  font-weight: 600;\n  background: transparent !important;\n  border-left: 2px solid #B8945A;\n  padding-left: calc(1.25rem - 2px); }\n\n/* Child links — quieter */\n.td-sidebar-nav ul ul a {\n  color: #5a5a5a;\n  font-weight: 400;\n  padding: 0.2rem 1.25rem 0.2rem 2rem; }\n\n.td-sidebar-nav ul ul a:hover {\n  color: #0a0a0a;\n  text-decoration: none; }\n\n/* ── Content Page Typography ───────────────────────────── */\n.td-content {\n  font-size: 1rem;\n  line-height: 1.8;\n  color: #1a1a1a;\n  max-width: 72ch;\n  /* optimal reading width */\n  margin-left: 0; }\n\n.td-content h1, .td-content .h1 {\n  font-family: 'Playfair Display', serif;\n  font-size: 2.2rem;\n  font-weight: 900;\n  letter-spacing: -0.025em;\n  margin-bottom: 0.25rem; }\n\n.td-content h2, .td-content .h2 {\n  font-family: 'Playfair Display', serif;\n  font-size: 1.5rem;\n  font-weight: 700;\n  margin-top: 2.5rem;\n  padding-top: 1.5rem;\n  border-top: 1px solid #e4e4e0; }\n\n.td-content h3, .td-content .h3, .td-content .td-footer__links-item {\n  font-family: 'DM Sans', sans-serif;\n  font-size: 1.1rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: #5a5a5a;\n  margin-top: 1.75rem; }\n\n.td-content p {\n  margin-bottom: 1.1rem; }\n\n/* Code blocks — improved */\n.td-content pre {\n  background: #f4f3ef;\n  border: 1px solid #e4e4e0;\n  border-radius: 3px;\n  padding: 1.25rem 1.5rem;\n  font-size: 0.8125rem;\n  line-height: 1.7; }\n\n.td-content code {\n  background: #f0ede6;\n  color: #8a4a1a;\n  padding: 0.1em 0.35em;\n  border-radius: 2px;\n  font-size: 0.85em; }\n\n/* KaTeX math blocks — give them breathing room */\n\n.td-footer {\n  margin: 0 !important;\n  padding: 0 !important;\n  min-height: auto !important;\n  border: none !important; }\n\n/* ── Sidebar active state — gold, not blue ─────── */\n.td-sidebar-nav a.td-sidebar-link.active,\n.td-sidebar-nav a.td-sidebar-link:active,\n.td-sidebar-nav .active > a.td-sidebar-link,\n.td-sidebar-nav li.active a {\n  color: #0f172a !important;\n  font-weight: 600 !important;\n  background: transparent !important;\n  background-color: transparent !important;\n  border-left: 2px solid #B8945A !important;\n  padding-left: calc(1rem - 2px) !important;\n  text-decoration: none !important; }\n\n/* Kill the blue link color inside docs content too */\n.td-sidebar .td-sidebar-nav__section-title .td-sidebar-link:hover,\n.td-sidebar-nav a:hover {\n  color: #0f172a !important;\n  text-decoration: none !important; }\n\n/* Section title (L1 headings like \"COURSES\") */\n.td-sidebar-nav .td-sidebar-nav__section-title a {\n  font-size: 0.72rem !important;\n  font-weight: 700 !important;\n  letter-spacing: 0.1em !important;\n  text-transform: uppercase !important;\n  color: #5a5a5a !important; }\n\n.rs-course-overview__expand {\n  color: #B8945A; }\n\n.rs-course-overview__expand:hover {\n  color: #9a7340;\n  text-decoration: underline; }\n\n.rs-course-outline__item-meta a {\n  color: #B8945A; }\n\n.rs-course-outline__item-meta a:hover {\n  color: #9a7340; }\n\n.td-navbar {\n  transition: border-bottom-color 0.2s ease;\n  border-bottom: 1px solid transparent !important; }\n\n.video-btn-playlist {\n  background-color: #fdf9f4;\n  border-color: #e8ddd0; }\n\n.video-btn-playlist .video-btn__icon {\n  background: #f5ede0;\n  color: #9a6f38;\n  /* gold icon */ }\n\n.video-btn-playlist:hover {\n  background-color: #faf4ec;\n  border-color: #d4c4a8;\n  box-shadow: 0 8px 20px rgba(184, 148, 90, 0.1); }\n\n.rs-about-section {\n  padding: 0.2rem 0 4rem; }\n\n.rs-creator-card {\n  display: grid;\n  grid-template-columns: auto 1fr;\n  gap: 2rem;\n  align-items: flex-start;\n  max-width: 760px;\n  margin: 0 auto;\n  padding: 2rem;\n  border: 1px solid #e8ddd0;\n  border-radius: 1rem;\n  background: linear-gradient(135deg, #fffdf9 0%, #ffffff 60%); }\n\n.rs-creator-card__avatar {\n  width: 72px;\n  height: 72px;\n  border-radius: 50%;\n  background: #0a0a0a;\n  color: #fff;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: 'Playfair Display', serif;\n  font-size: 1.4rem;\n  font-weight: 900;\n  flex-shrink: 0; }\n\n.rs-creator-card__name {\n  font-family: 'Playfair Display', serif;\n  font-size: 1.65rem;\n  font-weight: 700;\n  color: #0a0a0a;\n  letter-spacing: -0.02em;\n  margin-bottom: 0.6rem; }\n\n.rs-creator-card__bio {\n  font-size: 0.96rem;\n  color: #5b667a;\n  line-height: 1.75;\n  margin-bottom: 1.5rem;\n  font-style: italic; }\n\n.rs-creator-card__creds {\n  display: grid;\n  gap: 0.85rem; }\n\n.rs-cred {\n  display: grid;\n  grid-template-columns: 28px 1fr;\n  gap: 0.6rem;\n  align-items: flex-start;\n  padding: 0.7rem 0.85rem;\n  border: 1px solid #e8ddd0;\n  border-radius: 8px;\n  background: #ffffff; }\n\n.rs-cred__icon {\n  color: #B8945A;\n  font-size: 0.9rem;\n  padding-top: 2px; }\n\n.rs-cred__label {\n  display: block;\n  font-size: 0.68rem;\n  font-weight: 700;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  color: #8a8a8a;\n  margin-bottom: 0.1rem; }\n\n.rs-cred__text {\n  display: block;\n  font-size: 0.9rem;\n  font-weight: 600;\n  color: #0f172a;\n  line-height: 1.3; }\n\n.rs-cred__sub {\n  display: block;\n  font-size: 0.8rem;\n  color: #8a8a8a;\n  margin-top: 0.1rem; }\n\n@media (max-width: 600px) {\n  .rs-creator-card {\n    grid-template-columns: 1fr;\n    gap: 1.25rem; } }\n\n@media (min-width: 1200px) {\n  /* Targets ONLY documentation pages (single & list views) that contain `.td-content`.\n     This completely protects your Home page and About page from layout distortion.\n  */\n  body:has(.td-content) {\n    /* 1. Open up the outermost shell to utilize full widescreen real estate */\n    /* 2. Convert primary theme rows into an unconstrained flex system */\n    /* 3. Keep the Left Navigation Sidebar clean and compact */\n    /* 4. SHATTER THE COL-XL-8 CONSTRAINT: Force main block to take ALL remaining space */\n    /* 5. Remove internal structural restrictions */\n    /* 6. Clean split arrangement with an optimized layout gap */\n    /* 7. MAXIMUM VISUAL PRIORITY: Center track expands to capture all available space */\n    /* 8. Keep the right tracking panel locked in place perfectly */ }\n    body:has(.td-content) .container-fluid.td-outer {\n      max-width: 100% !important;\n      width: 100% !important;\n      padding-left: 2rem !important;\n      padding-right: 2rem !important; }\n    body:has(.td-content) .td-main,\n    body:has(.td-content) .td-main > .row.flex-xl-nowrap {\n      display: flex !important;\n      width: 100% !important;\n      max-width: 100% !important;\n      margin-left: 0 !important;\n      margin-right: 0 !important; }\n    body:has(.td-content) .td-sidebar {\n      flex: 0 0 240px !important;\n      max-width: 240px !important;\n      width: 240px !important;\n      padding-left: 0 !important;\n      padding-right: 1rem !important; }\n    body:has(.td-content) main.col-xl-8,\n    body:has(.td-content) main.col-md-7,